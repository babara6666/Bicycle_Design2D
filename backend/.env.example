# Copy this file to .env and fill in your values.
# DO NOT commit .env — it contains secrets.

DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@localhost:5432/ibds2d
ALLOWED_SOURCE_DIR=D:\path\to\DWG
ALLOWED_OUTPUT_DIR=D:\path\to\Bicycle2D\Output
DXF_SOURCE_DIR=D:\path\to\Bicycle2D\backend\data\dxf_source
SVG_OUTPUT_DIR=D:\path\to\Bicycle2D\backend\data\svg
ATTACH_POINTS_JSON=D:\path\to\Bicycle2D\backend\data\attach_points_all.json
GEMINI_API_KEY=your-google-gemini-api-key-here
